NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://fairgig:fairgig@localhost:5432/fairgig
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173
# Firebase Admin credentials (preferred: GOOGLE_APPLICATION_CREDENTIALS file path)
# GOOGLE_APPLICATION_CREDENTIALS=
# Optional inline credentials for non-file environments:
FIREBASE_PROJECT_ID=softec-webhackathon
ANTHROPIC_API_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Optional for local Data Connect emulator (example: localhost:9399)
DATACONNECT_EMULATOR_HOST=
